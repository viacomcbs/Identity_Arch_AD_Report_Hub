{
  "name": "ad-identity-tool",
  "version": "1.0.0",
  "description": "Active Directory Identity Tool - Professional AD Management Interface",
  "scripts": {
    "start": "concurrently --kill-others-on-fail \"npm run server\" \"npm run client\"",
    "client": "react-scripts start",
    "server": "node server/index.js",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "start:prod": "cross-env NODE_ENV=production node server/index.js",
    "build:serve": "npm run build && npm run start:prod",
    "pm2:start": "npm run build && pm2 start ecosystem.config.js --env production",
    "pm2:stop": "pm2 stop ad-report-hub",
    "pm2:restart": "pm2 restart ad-report-hub",
    "pm2:reload": "pm2 reload ad-report-hub",
    "pm2:logs": "pm2 logs ad-report-hub",
    "pm2:status": "pm2 status",
    "pm2:delete": "pm2 delete ad-report-hub",
    "pm2:save": "pm2 save"
  },
  "dependencies": {
    "axios": "^1.15.0",
    "concurrently": "^8.2.2",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "express-session": "^1.19.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.0",
    "react-scripts": "5.0.1",
    "vis-data": "^8.0.3",
    "vis-network": "^10.0.2",
    "xlsx": "^0.18.5"
  },
  "proxy": "http://localhost:5000",
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "cross-env": "^10.1.0"
  }
}
